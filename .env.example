# Database
DATABASE_URL="postgresql://postgres:CHANGE_ME@localhost:5432/simplepm"
DB_PASSWORD="CHANGE_ME"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Google OAuth (from Google Cloud Console)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# HIPAA: PHI encryption key — 32 random bytes as 64-char hex
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PHI_ENCRYPTION_KEY=""

# Domain restriction — only users from this domain can log in
ALLOWED_EMAIL_DOMAIN="yourhospital.org"

# Google Drive — Service Account (base64-encoded JSON)
GOOGLE_SERVICE_ACCOUNT_KEY_B64=""

# Email notifications (SMTP) — for @mention emails on comments.
# NOT HIPAA-hardened; for non-PHI notifications until a proper provider is set up.
# Gmail: SMTP_USER = the address, SMTP_PASS = a Google "App Password" (not the
# normal password). Leave blank to disable email entirely.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM=""

# Email via HTTPS API (works on hosts that block SMTP, e.g. DigitalOcean).
# Resend (resend.com): create an API key; verify your domain to send from
# @balidoc.com, or use onboarding@resend.dev for testing. Takes priority over SMTP.
RESEND_API_KEY=""

# Google Apps Script email relay (sends via your own Gmail; no DNS, no SMTP).
# GAS_EMAIL_URL = the deployed web-app URL; GAS_EMAIL_SECRET = shared secret.
GAS_EMAIL_URL=""
GAS_EMAIL_SECRET=""
