# Database
DATABASE_URL="postgresql://postgres:CHANGE_ME@localhost:5432/simplepm"
DB_PASSWORD="CHANGE_ME"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Google OAuth (from Google Cloud Console)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# HIPAA: PHI encryption key — 32 random bytes as 64-char hex
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PHI_ENCRYPTION_KEY=""

# Domain restriction — only users from this domain can log in
ALLOWED_EMAIL_DOMAIN="yourhospital.org"

# Google Drive — Service Account (base64-encoded JSON)
GOOGLE_SERVICE_ACCOUNT_KEY_B64=""

# Email notifications (task/project assignments + @mentions). SMTP via nodemailer.
# For Gmail: create an App Password (Google Account → Security → App passwords)
# and use it as SMTP_PASS. Host defaults to smtp.gmail.com when omitted.
# If SMTP_USER/SMTP_PASS are unset, emails are skipped (logged) — the app still works.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="info.balidoctor@gmail.com"
SMTP_PASS=""
EMAIL_FROM="BaliDoc <info.balidoctor@gmail.com>"

# Absolute base URL used to build deep links in emails (falls back to NEXTAUTH_URL)
APP_URL="http://localhost:3000"

# HIPAA: keep "false". Emails then contain NO PHI (no task titles / comment text),
# only a notice + a secure deep link. Only set "true" on a BAA-covered sending
# setup (e.g. Google Workspace with a signed BAA).
EMAIL_INCLUDE_PHI="false"
