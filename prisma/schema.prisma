generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  passwordHash  String?
  avatarUrl     String?
  role          Role      @default(MEMBER)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  lastSeenAt    DateTime?

  projectMemberships ProjectMember[]
  assignedTasks      Task[]          @relation("AssignedTo")
  createdTasks       Task[]          @relation("CreatedBy")
  comments           Comment[]
  auditLogs          AuditLog[]
  feedback           Feedback[]
  notifications      Notification[]
}

// In-app notifications (feedback: multi-assignee broadcast + deep-linking).
// message is encrypted like task titles — it usually contains one.
model Notification {
  id         String    @id @default(cuid())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  actorName  String? // denormalized display name; avoids a join
  type       String // COMMENT | MENTION | STATUS | ASSIGNED | UPDATE
  messageEnc String
  taskId     String?
  projectId  String?
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

enum Role {
  ADMIN
  MEMBER
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  archivedAt  DateTime?

  // Sidebar sort position (feedback #5). Fractional so a project can be dragged
  // between two others by only rewriting its own value. Shared/global order.
  order       Float    @default(0)

  // Hidden, admin-only "Staging" projects (imported from Asana). Never shown to
  // workers; surfaced only in the admin Staging view.
  isStaging   Boolean  @default(false)
  asanaId     String?  @unique

  members     ProjectMember[]
  tasks       Task[]
  columns     Column[]
}

model ProjectMember {
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  joinedAt  DateTime @default(now())

  @@unique([projectId, userId])
}

model Column {
  id        String   @id @default(cuid())
  name      String
  order     Int
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks     Task[]
}

model Task {
  id             String    @id @default(cuid())
  titleEnc       String
  descriptionEnc String?
  goalEnc        String?
  expectedOutputEnc String?
  qualityRequirementsEnc String?
  problemEnc     String?
  currentWorkflowEnc String?
  desiredImprovementEnc String?
  automationOpportunityEnc String?

  status         TaskStatus @default(TODO)
  priority       Priority   @default(MEDIUM)
  dueDate        DateTime?
  order          Float      @default(0)
  template       String     @default("general")
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  completedAt    DateTime?

  // Asana import + staging-distribution bookkeeping.
  asanaId          String?   @unique   // source Asana task GID (idempotent import); copies have null
  distributedAt    DateTime?           // set on a staged task once copied into a real project (drives the color change)
  originalAssignee String?             // original Asana assignee name/email, kept as text even for non-users; carried onto copies

  project        Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId      String
  column         Column?    @relation(fields: [columnId], references: [id])
  columnId       String?
  assignee       User?      @relation("AssignedTo", fields: [assigneeId], references: [id])
  assigneeId     String?
  createdBy      User       @relation("CreatedBy", fields: [createdById], references: [id])
  createdById    String

  parentTask     Task?      @relation("Subtasks", fields: [parentTaskId], references: [id], onDelete: Cascade)
  parentTaskId   String?
  subtasks       Task[]     @relation("Subtasks")

  comments       Comment[]
  attachments    Attachment[]
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

model Comment {
  id         String   @id @default(cuid())
  bodyEnc    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  asanaId    String?  @unique   // source Asana story GID (idempotent import)

  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId     String
  author     User     @relation(fields: [authorId], references: [id])
  authorId   String
}

model Attachment {
  id           String   @id @default(cuid())
  fileName     String
  mimeType     String
  driveFileId  String
  driveViewUrl String
  sizeBytes    Int
  uploadedAt   DateTime @default(now())

  task         Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId       String
  uploadedById String
}

model AuditLog {
  id         String      @id @default(cuid())
  occurredAt DateTime    @default(now())
  actorId    String?
  actor      User?       @relation(fields: [actorId], references: [id])
  action     AuditAction
  resource   String
  resourceId String
  metadata   Json?
  ipAddress  String?
  userAgent  String?
}

enum AuditAction {
  USER_LOGIN
  USER_LOGOUT
  USER_SESSION_TIMEOUT
  TASK_VIEWED
  TASK_CREATED
  TASK_UPDATED
  TASK_DELETED
  COMMENT_CREATED
  COMMENT_UPDATED
  COMMENT_DELETED
  ATTACHMENT_UPLOADED
  ATTACHMENT_DOWNLOADED
  ATTACHMENT_DELETED
  USER_ROLE_CHANGED
  USER_DEACTIVATED
  USER_REACTIVATED
  PROJECT_CREATED
  PROJECT_UPDATED
  PROJECT_DELETED
  PROJECT_ARCHIVED
  PROJECT_MEMBER_ADDED
  PROJECT_MEMBER_REMOVED
  FEEDBACK_SUBMITTED
  FEEDBACK_STATUS_CHANGED
}

model Feedback {
  id             String              @id @default(cuid())
  rawText        String
  conversation   String?
  pageContext    String?
  url            String?

  title          String?
  category       FeedbackCategory?
  complexity     FeedbackComplexity?
  summary        String?
  aiProcessed    Boolean             @default(false)

  status         FeedbackStatus      @default(NEW)
  triageNotes    String?
  resolvedCommit String?
  resolvedAt     DateTime?

  submittedBy    User                @relation(fields: [submittedById], references: [id])
  submittedById  String
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([status])
  @@index([createdAt])
}

enum FeedbackStatus {
  NEW
  TRIAGED
  FIXED
  NEEDS_OWNER
  WONT_FIX
}

enum FeedbackCategory {
  BUG
  FEATURE_REQUEST
  UI_UX
  PERFORMANCE
  COPY_TEXT
  OTHER
}

enum FeedbackComplexity {
  SIMPLE
  COMPLEX
  UNKNOWN
}
